  </ItemGroup>
  <ItemGroup>
    <Folder Include="wwwroot\" />
    <Folder Include="AppData\Log\" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="docker-compose.override.yml" />
    <None Remove="EPPlus" />
    <None Remove="Microsoft.AspNetCore.Mvc" />
    <None Remove="StackExchange.Redis" />
